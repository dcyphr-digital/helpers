{
    "name": "dcyphr-digital/helpers",
    "description": "Shared Laravel helpers for Dcyphr projects (import cleaning, AU state/postcode, deduplication).",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Dcyphr Digital"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nesbot/carbon": "^3.0",
        "ext-zlib": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "DcyphrDigital\\Helpers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DcyphrDigital\\Helpers\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DcyphrDigital\\Helpers\\DcyphrHelpersServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
